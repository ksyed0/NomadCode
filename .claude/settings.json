{
  "enabledPlugins": {
    "vercel@claude-plugins-official": false,
    "stripe@claude-plugins-official": false,
    "supabase@claude-plugins-official": false
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node /Users/Kamal_Syed/Projects/NomadCode/tools/capture-cost.js --capture-baseline"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$(git rev-parse --show-toplevel)\" && node tools/capture-cost.js"
          }
        ]
      }
    ]
  }
}
