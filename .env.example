# GitHub OAuth App credentials (required for OAuth sign-in flow — see EPIC-0007)
#
# SECURITY NOTE: EXPO_PUBLIC_* variables are inlined into the app binary at build
# time. EXPO_PUBLIC_GITHUB_CLIENT_ID is a public value and safe to include here.
# EXPO_PUBLIC_GITHUB_CLIENT_SECRET must be replaced with a server-side proxy
# endpoint before any production release — never ship a production client_secret
# in the app bundle.
EXPO_PUBLIC_GITHUB_CLIENT_ID=your_github_oauth_app_client_id
EXPO_PUBLIC_GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret_dev_only
GITHUB_REDIRECT_URI=nomadcode://auth
