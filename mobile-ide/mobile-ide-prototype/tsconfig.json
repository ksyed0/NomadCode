{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "moduleResolution": "bundler",
    "ignoreDeprecations": "6.0",
    "typeRoots": [
      "./node_modules/@types",
      "../node_modules/@types"
    ],
    "types": ["jest", "node"],
    "baseUrl": ".",
    "paths": {
      "@components/*": [
        "src/components/*"
      ],
      "@utils/*": [
        "src/utils/*"
      ],
      "@layout/*": [
        "src/layout/*"
      ],
      "@extensions/*": [
        "src/extensions/*"
      ],
      "@assets/*": [
        "assets/*"
      ],
      "@stores/*": [
        "src/stores/*"
      ],
      "@git/*": [
        "src/git/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "tests/e2e"
  ]
}
