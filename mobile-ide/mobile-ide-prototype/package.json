{
  "name": "mobile-ide-prototype",
  "version": "0.1.0",
  "description": "NomadCode mobile IDE prototype",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo export",
    "size": "size-limit",
    "test": "jest --watchAll=false",
    "test:coverage": "jest --watchAll=false --coverage",
    "test:e2e": "detox test --configuration ios.ipad.debug",
    "test:e2e:android": "detox test --configuration android.emu.debug",
    "test:e2e:build:ios": "detox build --configuration ios.ipad.debug",
    "test:e2e:build:android": "detox build --configuration android.emu.debug",
    "build:terminal": "node src/terminal/bundle/build.js",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/metro-runtime": "~4.0.1",
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo": "~52.0.0",
    "expo-auth-session": "~6.0.3",
    "expo-crypto": "~14.0.2",
    "expo-document-picker": "~13.0.3",
    "expo-file-system": "~18.0.12",
    "expo-secure-store": "~14.0.1",
    "expo-status-bar": "~2.0.1",
    "expo-web-browser": "~14.0.2",
    "isomorphic-git": "^1.37.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.0",
    "react-native-web": "~0.19.13",
    "react-native-webview": "^13.12.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@size-limit/preset-app": "^12.0.1",
    "@testing-library/react-native": "^12.8.0",
    "@types/jest": "^29.5.0",
    "@types/react": "~18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "detox": "^20.0.0",
    "esbuild": "^0.27.4",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.0",
    "jest-junit": "^16.0.0",
    "prettier": "^3.8.1",
    "react-test-renderer": "18.3.1",
    "size-limit": "^12.0.1",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "cacache": ">=20.0.0"
  },
  "jest": {
    "preset": "jest-expo",
    "coverageDirectory": "../../docs/coverage",
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/terminal/bundle/**"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "coverageReporters": [
      "text",
      "lcov",
      "json-summary",
      "json"
    ],
    "testResultsProcessor": "jest-junit",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|react-native-webview|isomorphic-git)"
    ]
  }
}
